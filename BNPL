<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Калькулятор выгоды BNPL — Robokassa</title>
    
    <link rel="icon" type="image/png" href="v-rk-32.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geologica:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --rk-blue:        #525FFB;
            --rk-blue-hover:  #3D49F0;
            --rk-blue-light:  #EEEEFF;
            --rk-dark:        #000000;
            --rk-text:        #1A1A1A;
            --rk-text-muted:  #6B7394;
            --rk-success:     #0D9F6E;
            --rk-success-bg:  #EDFAF5;
            --rk-bg:          #F2F5FA;
            --rk-white:       #FFFFFF;
            --rk-border:      #E2E7F1;
            --rk-radius:      20px;
            --rk-font:        'Geologica', sans-serif;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: var(--rk-font);
            background: var(--rk-bg);
            color: var(--rk-text);
            padding: 40px 20px;
            -webkit-font-smoothing: antialiased;
        }

        .container { max-width: 860px; margin: 0 auto; display: flex; flex-direction: column; }

        .rk-header { display: flex; justify-content: flex-start; margin-bottom: 24px; }
        .rk-logo-img { height: 16px; width: auto; } 

        .calc-title { text-align: center; margin-bottom: 32px; }
        .calc-title h1 { font-size: 28px; font-weight: 700; color: var(--rk-dark); margin-bottom: 8px; }
        .calc-title p { font-size: 15px; color: var(--rk-text-muted); }

        .section { background: var(--rk-white); border: 1px solid var(--rk-border); border-radius: var(--rk-radius); padding: 28px; margin-bottom: 16px; }
        h3 { font-size: 13px; font-weight: 600; text-transform: uppercase; color: var(--rk-text-muted); margin-bottom: 20px; }

        .grid-inputs { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .input-group { margin-bottom: 14px; }
        label { display: block; font-size: 11px; font-weight: 500; color: var(--rk-text-muted); margin-bottom: 6px; }
        input { width: 100%; padding: 11px; border: 1.5px solid var(--rk-border); border-radius: 8px; background: var(--rk-bg); font-family: var(--rk-font); font-size: 15px; }

        .btn-calc-wrapper { display: flex; justify-content: center; margin: 24px 0; }
        .btn-calc { width: 100%; max-width: 320px; background-color: var(--rk-blue); color: #fff; border: none; padding: 16px; font-size: 16px; font-weight: 600; border-radius: 8px; cursor: pointer; }

        .results-section { background: var(--rk-white); border: 1px solid var(--rk-border); border-radius: var(--rk-radius); padding: 28px; }
        .results-table { width: 100%; border-collapse: collapse; }
        .results-table th { font-size: 11px; color: var(--rk-text-muted); padding-bottom: 12px; border-bottom: 2px solid var(--rk-border); text-align: center; }
        .results-table td { padding: 13px; font-size: 14px; text-align: center; border-bottom: 1px solid var(--rk-border); }
        .results-table td:first-child { text-align: left; color: var(--rk-text-muted); }
        .highlight { background: var(--rk-blue-light); color: var(--rk-blue); font-weight: 700; }

        .profit-diff { margin-top: 20px; padding: 20px; border-radius: 12px; background: var(--rk-success-bg); color: var(--rk-success); border: 1.5px solid #B2ECDA; text-align: center; }
        .profit-main { font-size: 22px; font-weight: 700; }

        .print-only-footer { display: none; }

        @media print {
            @page { size: A4 portrait; margin: 10mm; }
            body { background: white !important; padding: 0 !important; }
            .no-print { display: none !important; }
            .container { height: 277mm; display: flex; flex-direction: column; }
            .section, .results-section { box-shadow: none !important; border: 1px solid #E2E7F1 !important; }
            .print-only-footer { display: flex !important; justify-content: space-between; margin-top: auto; padding-top: 15px; border-top: 1px solid var(--rk-border); font-size: 10px; color: var(--rk-text-muted); }
        }
    </style>
</head>
<body>

    <div class="container">
        <header class="rk-header">
            <img src="logo_robokassa_black.png" alt="Robokassa" class="rk-logo-img">
        </header>

        <div class="calc-title">
            <h1>Выгода от внедрения BNPL</h1>
            <p>Узнайте, сколько прибыли принесет рассрочка вашему бизнесу</p>
        </div>
        
        <div class="section">
            <h3>Вводные данные</h3>
            <div class="grid-inputs">
                <div class="input-group"><label>Текущий оборот, ₽</label><input type="number" id="turnover" value="2000000"></div>
                <div class="input-group"><label>Средний чек, ₽</label><input type="number" id="avgCheck" value="5000"></div>
                <div class="input-group"><label>Комиссия эквайринга, %</label><input type="number" id="rateAcq" value="3" step="0.1"></div>
                <div class="input-group"><label>Комиссия BNPL, %</label><input type="number" id="rateBnpl" value="7" step="0.1"></div>
                <div class="input-group"><label>Доля брошенных корзин, %</label><input type="number" id="abandoned" value="30"></div>
                <div class="input-group"><label>Спасение корзин с BNPL, %</label><input type="number" id="recovery" value="10"></div>
            </div>
        </div>

        <div class="btn-calc-wrapper no-print">
            <button class="btn-calc" onclick="calculate()">Рассчитать выгоду</button>
        </div>

        <div class="results-section">
            <h3>Результаты прогноза</h3>
            <table class="results-table">
                <thead>
                    <tr>
                        <th>Показатель</th>
                        <th>Без BNPL</th>
                        <th style="color: var(--rk-blue);">С Robokassa BNPL</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td>Общий оборот, ₽</td><td id="resTurnoverOld">0</td><td id="resTurnoverNew">0</td></tr>
                    <tr><td>Спасенные заказы, шт.</td><td>—</td><td id="resSavedOrders">0</td></tr>
                    <tr><td>Затраты на комиссию, ₽</td><td id="resFeeOld">0</td><td id="resFeeNew">0</td></tr>
                    <tr class="highlight"><td>Чистая прибыль, ₽</td><td id="resProfitOld">0</td><td id="resProfitNew">0</td></tr>
                </tbody>
            </table>
            
            <div class="profit-diff">
                <div class="profit-main" id="profitMain">✦ Дополнительная прибыль: 0 ₽ в мес.</div>
                <div id="profitYear" style="font-size: 14px; margin-top: 5px;">или 0 ₽ в год</div>
            </div>
            
            <div class="export-actions no-print">
                <button class="btn-calc" style="background:none; border:1.5px solid var(--rk-blue); color:var(--rk-blue)" onclick="window.print()">Сохранить в PDF</button>
            </div>
        </div>

        <footer class="print-only-footer">
            <div><strong>ООО «РОБОКАССА»</strong><br>ИНН 5047063929</div>
            <div style="text-align:center">115054, г. Москва,<br>Стремянный переулок д. 26</div>
            <div style="text-align:right">8 (499) 110-57-25<br>robokassa.com</div>
        </footer>
    </div>

    <script>
        function f(n) { return Math.round(n).toLocaleString('ru-RU'); }

        function calculate() {
            // Вводные
            const turn = parseFloat(document.getElementById('turnover').value) || 0;
            const avg = parseFloat(document.getElementById('avgCheck').value) || 1;
            const rAcq = (parseFloat(document.getElementById('rateAcq').value) || 0) / 100;
            const rBnpl = (parseFloat(document.getElementById('rateBnpl').value) || 0) / 100;
            const abandonedRate = (parseFloat(document.getElementById('abandoned').value) || 0) / 100;
            const recoveryRate = (parseFloat(document.getElementById('recovery').value) || 0) / 100;
            const migrationRate = 0.1; // Переток текущих оплат в BNPL (стандарт 10%)

            // 1. Ситуация БЕЗ BNPL
            const feeOld = turn * rAcq;
            const profitOld = turn - feeOld;

            // 2. Ситуация С BNPL
            // Считаем сколько корзин бросают
            const currentOrders = turn / avg;
            const lostOrders = (currentOrders / (1 - abandonedRate)) * abandonedRate;
            
            // Сколько заказов спасаем
            const savedOrders = lostOrders * recoveryRate;
            const additionalRev = savedOrders * avg;

            // Распределение нового оборота
            const migratedTurnover = turn * migrationRate; // Те, кто платил картой, ушли в BNPL
            const turnoverCard = turn - migratedTurnover;
            const turnoverBnpl = migratedTurnover + additionalRev;
            const turnoverNew = turnoverCard + turnoverBnpl;

            // Новая комиссия
            const feeNew = (turnoverCard * rAcq) + (turnoverBnpl * rBnpl);
            const profitNew = turnoverNew - feeNew;

            // Вывод
            document.getElementById('resTurnoverOld').innerText = f(turn);
            document.getElementById('resTurnoverNew').innerText = f(turnoverNew);
            document.getElementById('resSavedOrders').innerText = f(savedOrders);
            document.getElementById('resFeeOld').innerText = f(feeOld);
            document.getElementById('resFeeNew').innerText = f(feeNew);
            document.getElementById('resProfitOld').innerText = f(profitOld);
            document.getElementById('resProfitNew').innerText = f(profitNew);

            const diff = profitNew - profitOld;
            document.getElementById('profitMain').innerText = '✦ Дополнительная прибыль: + ' + f(diff) + ' ₽ в мес.';
            document.getElementById('profitYear').innerText = 'или + ' + f(diff * 12) + ' ₽ в год';
        }
        calculate();
    </script>
</body>
</html>
